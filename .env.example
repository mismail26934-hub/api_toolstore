# Salin ke .env untuk lokal: cp .env.example .env
# File .env jangan di-commit ke git.

APP_ENV=local
API_AUTH_REQUIRED=0

# Base URL API (untuk client / Postman)
# http://<host>:<port>/api_tool/api_toolstore/v1/<route>
# Contoh: POST .../v1/form  |  POST .../v1/auth/login

# --- Mode lokal (plaintext DB pass) ---
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=db_tools

# Auth API: set 1 setelah app client mengirim id_users + token di setiap request
# API_AUTH_REQUIRED=0

# --- Mode hosting (production) ---
# APP_ENV=production
# DB_HOST=127.0.0.1
# DB_USER=app_toolstore
# DB_NAME=db_tools
# DB_ENCRYPTION_KEY=ubah-dengan-string-panjang-random-min-32-karakter
# DB_PASS_ENCRYPTED=<hasil dari php conn/encrypt_password.php>
# Production wajib DB_ENCRYPTION_KEY + DB_PASS_ENCRYPTED (DB_PASS tidak dipakai)
# API_AUTH_REQUIRED=1
